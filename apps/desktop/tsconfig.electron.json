{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "electron-dist",
    "rootDir": "electron",
    "declaration": false,
    "noEmit": false
  },
  "include": ["electron/**/*.ts"]
}
