{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "electron-dist",
    "rootDir": "electron",
    "declaration": false,
    "noEmit": true
  },
  "include": ["electron/**/*.ts"]
}
