{
  "name": "@whisperall/desktop",
  "private": true,
  "version": "0.36.2-alpha",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:ai": "playwright test --config=playwright.ai.config.ts",
    "lint": "echo lint-not-configured",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "electron:dev": "tsc -p tsconfig.electron.json && node scripts/electron-dev.mjs",
    "bundle:backend": "node scripts/bundle-backend.mjs",
    "backend:sync": "node scripts/pre-dist.mjs",
    "build:full": "pnpm dist:dir",
    "dist:win": "node scripts/pre-dist.mjs && vite build && tsc -p tsconfig.electron.json && npx electron-builder --config electron-builder.yml --win nsis",
    "dist:dir": "node scripts/pre-dist.mjs && vite build && tsc -p tsconfig.electron.json && npx electron-builder --config electron-builder.yml --dir"
  },
  "dependencies": {
    "@milkdown/core": "^7.20.0",
    "@milkdown/plugin-clipboard": "^7.20.0",
    "@milkdown/plugin-history": "^7.20.0",
    "@milkdown/plugin-listener": "^7.20.0",
    "@milkdown/plugin-tooltip": "^7.20.0",
    "@milkdown/preset-commonmark": "^7.20.0",
    "@milkdown/preset-gfm": "^7.20.0",
    "@milkdown/prose": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@milkdown/utils": "^7.20.0",
    "@supabase/supabase-js": "^2.95.2",
    "@whisperall/api-client": "workspace:*",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@midscene/web": "^1.7.4",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^17.4.2",
    "electron": "33",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.0"
  }
}
