{
  "name": "@whisperall/desktop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "echo lint-not-configured",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.electron.json --noEmit",
    "electron:dev": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE; require('child_process').spawn(require('electron'), ['.'], {stdio:'inherit', env:process.env}).on('exit',c=>process.exit(c))\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.2",
    "@whisperall/api-client": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "33",
    "typescript": "^5.6.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.0"
  }
}
