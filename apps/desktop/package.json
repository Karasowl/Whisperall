{
  "name": "@whisperall/desktop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "echo lint-not-configured",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "electron:dev": "tsc -p tsconfig.electron.json && node scripts/electron-dev.mjs",
    "bundle:backend": "node scripts/bundle-backend.mjs",
    "dist:win": "node scripts/pre-dist.mjs && vite build && tsc -p tsconfig.electron.json && npx electron-builder --config electron-builder.yml --win nsis",
    "dist:dir": "node scripts/pre-dist.mjs && vite build && tsc -p tsconfig.electron.json && npx electron-builder --config electron-builder.yml --dir"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.2",
    "@tiptap/extension-bubble-menu": "^3.19.0",
    "@tiptap/extension-highlight": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@whisperall/api-client": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "33",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.0",
    "electron-builder": "^25.1.8"
  }
}

