ENV=dev
AUTH_DISABLED=false
USAGE_LIMITS_DISABLED=false

# Comma-separated list of origins (no trailing slash). If omitted:
# - prod defaults to https://whisperall.com, https://www.whisperall.com
# - dev defaults to localhost + production origins
CORS_ORIGINS=
# Optional regex for preview domains (example): ^https://.*\.vercel\.app$
CORS_ORIGIN_REGEX=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
GOOGLE_TTS_API_KEY=
DEEPL_API_KEY=
DEEPSEEK_API_KEY=
ENCRYPTION_KEY=
