.vscode
.claude

# Multi-agent coordination files — TRACKED (do NOT ignore)
!.agent-locks.json
!.agent-mail.json
!.agent-config.json
!AGENTS.md

# Environment secrets
.env
.env.local
.env.*.local
apps/api/.env
apps/desktop/.env

# Pylance
pyrightconfig.json

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
!ui/frontend/src/lib/
lib/
lib64/
!apps/desktop/src/lib/
!apps/desktop/src/lib/**
!apps/desktop/tests/lib/
!apps/desktop/tests/lib/**
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

syn_out/
checkpoints/
.gradio

# Virtual environments
venv/
.venv/
env/
ENV/

# Node / frontend artifacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
.next_old_*/
out/
.turbo/

# Electron build artifacts
electron/dist/
electron/out/
electron/frontend/
electron/dist-msi*/
apps/desktop/electron-dist/*.js
apps/desktop/electron-dist/*.js.map
apps/desktop/electron-dist/modules/

# Packaged backend artifacts
backend-dist/
backend-build/

# Runtime data (should live in OS app data, not repo)
/temp/
/transcriptions/
/history/
/output/
/voices/
/logs/
/presets/
/data/
/models/
/settings.json

# Ignore generated sample .wav files
**/*.wav

# Test/coverage artifacts
coverage/
test-results/
playwright-report/
.playwright/
.vercel
